      "link": null,
      "locked": false,
      "text": "                         = f\"\"\"\n                        You are a router in a multi-agent system.\n\n                        Available agents:\n\n                        {                                            }\n\n                        Rules:\n\n                        WorkflowAgent → emails, calendar events, tasks\n                        ResearchAgent → web search, research, information gathering\n\n                        Return ONLY the agent name.\n\n                        Example:\n                        WorkflowAgent\n                        \"\"\"\n\n                              = [\n            {\"role\": \"system\", \"content\":                       },\n            {\"role\": \"user\", \"content\":                 },\n        ]\n\n        router_response =               .chat(                       )",
      "fontSize": 3.2925548152234336,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "                         = f\"\"\"\n                        You are a router in a multi-agent system.\n\n                        Available agents:\n\n                        {                                            }\n\n                        Rules:\n\n                        WorkflowAgent → emails, calendar events, tasks\n                        ResearchAgent → web search, research, information gathering\n\n                        Return ONLY the agent name.\n\n                        Example:\n                        WorkflowAgent\n                        \"\"\"\n\n                              = [\n            {\"role\": \"system\", \"content\":                       },\n            {\"role\": \"user\", \"content\":                 },\n        ]\n\n        router_response =               .chat(                       )",
      "autoResize": false,
      "lineHeight": 1.25
    },
