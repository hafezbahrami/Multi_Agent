      "versionNonce": 969980143,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776079784340,
      "link": null,
      "locked": false,
      "text": "Look at the :  OutputType = Exe: this project produces a runnable program (the MCP server process).\nTargetFramework = net10.0: it expects .NET 10 installed to build/run.\nPlatformTarget = x64: it’s compiled for 64-bit",
      "fontSize": 1.5772911518266217,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Look at the :  OutputType = Exe: this project produces a runnable program (the MCP server process).\nTargetFramework = net10.0: it expects .NET 10 installed to build/run.\nPlatformTarget = x64: it’s compiled for 64-bit",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
