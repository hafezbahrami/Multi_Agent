      "updated": 1773919281381,
      "link": null,
      "locked": false,
      "text": "    \"send_email\" → ToolMeta {\n        Method      = EmailSkill.send_email,\n        Description = \"Send, read, and manage emails\",\n        Parameters  = [\"to\", \"body\", \"subject\"]\n    },\n\n    \"create_event\" → ToolMeta {\n        Method      = CalendarSkill.create_event,\n        Description = \"Create and manage calendar events\",\n        Parameters  = [\"title\", \"date\", \"time\"]\n    },\n\n    \"create_task\" → ToolMeta {\n        Method      = TaskSkill.create_task,\n        Description = \"Create and manage tasks\",\n        Parameters  = [\"task\", \"priority\"]\n    }\n",
      "fontSize": 1.1245049952442785,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "    \"send_email\" → ToolMeta {\n        Method      = EmailSkill.send_email,\n        Description = \"Send, read, and manage emails\",\n        Parameters  = [\"to\", \"body\", \"subject\"]\n    },\n\n    \"create_event\" → ToolMeta {\n        Method      = CalendarSkill.create_event,\n        Description = \"Create and manage calendar events\",\n        Parameters  = [\"title\", \"date\", \"time\"]\n    },\n\n    \"create_task\" → ToolMeta {\n        Method      = TaskSkill.create_task,\n        Description = \"Create and manage tasks\",\n        Parameters  = [\"task\", \"priority\"]\n    }\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
