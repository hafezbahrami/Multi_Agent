      "link": null,
      "locked": false,
      "text": "Look at the : Package dependencies: (Microsoft.Extensions.Hosting: gives you the standard .NET “host” pattern (DI, lifetime, logging patterns).\nModelContextProtocol: the library that implements MCP server plumbing + tool registration attributes.)",
      "fontSize": 1.5772911518266217,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Look at the : Package dependencies: (Microsoft.Extensions.Hosting: gives you the standard .NET “host” pattern (DI, lifetime, logging patterns).\nModelContextProtocol: the library that implements MCP server plumbing + tool registration attributes.)",
      "autoResize": true,
      "lineHeight": 1.25
